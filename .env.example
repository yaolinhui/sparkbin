# ==========================================
# SparkBin Environment Configuration
# Copy this file to .env and fill in values
# ==========================================

# ------------------------------
# Security (REQUIRED)
# ------------------------------
# JWT signing key - generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-min-32-chars-long!!!

# API key encryption - generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=change-me-in-production-min-32-chars-long!!!

# Initial admin password - change immediately after first login
DEFAULT_PASSWORD=changeme

# ------------------------------
# Database (REQUIRED)
# ------------------------------
# SQLite (development): sqlite:///./sparkbin.db
# PostgreSQL (production): postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://sparkbin:changeme@postgres:5432/sparkbin

# ------------------------------
# CORS (REQUIRED for production)
# ------------------------------
# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost,http://localhost:5173

# ------------------------------
# Frontend Build (for Docker)
# ------------------------------
# Backend API URL injected at build time
VITE_API_URL=http://localhost:8000

# ------------------------------
# OAuth Login (Optional)
# ------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost

# ------------------------------
# Email Service (Optional)
# ------------------------------
# For email registration and password reset
RESEND_API_KEY=
RESEND_FROM_EMAIL=SparkBin <noreply@yourdomain.com>

# ------------------------------
# Stripe Payments (Optional)
# ------------------------------
# Leave empty to disable payment features
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
APP_URL=http://localhost

# ------------------------------
# GitHub Backup (Optional)
# ------------------------------
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_FILE_PATH=data/projects.json
