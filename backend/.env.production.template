# SparkBin 后端生产环境变量模板
# 部署到 Render 时，在 Render Dashboard → Environment 中逐项设置
# 切勿将此文件提交到 Git！

# ========== 数据库（Render PostgreSQL）==========
# 从 Render Dashboard → PostgreSQL → Connect 中获取 Internal Database URL
DATABASE_URL=postgresql://sparkbin:password@hostname.render.com:5432/sparkbin

# ========== 安全密钥（必须替换！）==========
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-production-secret-key-min-32-chars

# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-production-fernet-key

# ========== 初始管理员（部署后第一时间修改密码！）==========
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=change-this-immediately

# ========== 后端配置 ==========
API_PORT=8000
DEBUG=false
# CORS 必须包含前端生产域名
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-landing.vercel.app

# ========== 商业模式（MVP 建议关闭支付）==========
ENABLE_PAYMENTS=false
ENABLE_SAAS_FEATURES=false
CREDITS_GRANT_ON_REGISTER=20
CREDITS_PACKS=5:100,10:250,20:600

# ========== Stripe（关闭支付时无需填写）==========
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
APP_URL=https://your-frontend.vercel.app

# ========== 邮件服务（Resend）==========
# 注册 https://resend.com 获取 API key，并验证域名
RESEND_API_KEY=
RESEND_FROM_EMAIL=SparkBin <noreply@your-domain.com>

# ========== OAuth（可选，关闭时留空）==========
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=https://your-frontend.vercel.app

# ========== GitHub 备份（可选）==========
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_FILE_PATH=data/projects.json

# ========== 代理配置（如需访问外网 AI API）==========
HTTP_PROXY=
HTTPS_PROXY=
