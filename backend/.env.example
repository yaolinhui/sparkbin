# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/sparkbin

# 安全密钥（必须修改！）
SECRET_KEY=your-secret-key-for-jwt-here-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here-chang  # Fernet 密钥，必须 32 字节 base64

# 初始管理员账号（启动时自动创建）
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin

# 后端配置
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# GitHub 配置（保留备份功能）
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_data_repo
GITHUB_FILE_PATH=data/projects.json

# Stripe 支付配置（测试模式）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
APP_URL=http://localhost:5173
