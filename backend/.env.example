# ==========================================
# SparkBin Backend Environment Configuration
# Copy this file to .env and fill in your values
# ==========================================

# Database (SQLite or PostgreSQL)
# SQLite example (simplest for self-hosting):
DATABASE_URL=sqlite:///./sparkbin.db
# PostgreSQL example (production recommendation):
# DATABASE_URL=postgresql://user:password@localhost:5432/sparkbin

# Security Keys (MUST be changed for production!)
# Generate a strong secret key, e.g.:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-your-secret-key-min-32-chars

# Generate a 32-byte encryption key, e.g.:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=changeme-your-32-byte-encryption-key-here

# Initial Admin Account (created on first startup)
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=changeme-strong-password

# API Server Port
API_PORT=8000

# CORS Origins (comma-separated, no spaces)
# Add your frontend URL(s) here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Stripe Payment Configuration (Optional)
# Leave empty for self-hosted mode (no payment features)
# Test mode key starts with sk_test_
# Live mode key starts with sk_live_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
APP_URL=http://localhost:5173

# GitHub Backup Configuration (Optional)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_FILE_PATH=data/projects.json

# Email Service (Resend) - Optional, leave empty to mock emails in dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=SparkBin <noreply@sparkbin.dev>

# OAuth 2.0 Configuration (Optional)
# Register apps at: https://console.cloud.google.com/ (Google) and https://github.com/settings/developers (GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
